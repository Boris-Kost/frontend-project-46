{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "import/extensions": "off",
    "semi": ["error", "never"],
    "arrow-parens": "off",
    "no-underscore-dangle": ["error", { "allow": ["__filename", "__dirname"] }],
    "object-curly-newline": "off"
  }
}
